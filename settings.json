{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(shred *)",
      "Bash(wipefs *)",
      "Bash(fdisk *)",
      "Bash(parted *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "paplay /home/Maxime/.claude/song/finish.mp3"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "paplay /home/Maxime/.claude/song/need-human.mp3"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun /home/Maxime/.claude/scripts/statusline/src/index.ts",
    "padding": 0
  },
  "enabledPlugins": {
    "exa@claude-plugins-official": true,
    "qt-development-skills@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "teammateMode": "in-process"
}
